<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane style="-fx-background-color: #F1F5F9;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.tpvfacil.hosteleria.controller.MesasController">

    <!-- ── CABECERA OSCURA ──────────────────────────────────────── -->
    <top>
        <VBox>
            <HBox styleClass="header-app" alignment="CENTER_LEFT" spacing="16">
                <Label text="🧾 TPVFácil" styleClass="header-logo" />
                <Label text="Hostelería"  styleClass="header-modulo" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="📋 Carta"    onAction="#abrirGestionCarta"  styleClass="header-btn" />
                <Button text="🔒 Caja"     onAction="#abrirCierreCaja"    styleClass="header-btn" />
                <Button text="+ Mesa"      onAction="#abrirNuevaMesa"
                        style="-fx-background-color: #16A34A; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-font-size: 12px;
                               -fx-background-radius: 6; -fx-border-radius: 6;
                               -fx-padding: 5 14; -fx-cursor: hand;" />
                <Button text="⬅ Inicio"   onAction="#volverInicio"       styleClass="header-btn-volver" />
            </HBox>

            <MenuBar styleClass="menu-bar" style="-fx-padding: 1 8;">
                <Menu text="Más opciones">
                    <MenuItem text="Salir de la aplicación" onAction="#salir" />
                </Menu>
            </MenuBar>
        </VBox>
    </top>

    <!-- ── CONTENIDO ──────────────────────────────────────────────── -->
    <center>
        <VBox spacing="0">
            <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>

            <!-- Leyenda de estados -->
            <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-padding: 0 0 14 2;">
                <HBox spacing="6" alignment="CENTER">
                    <Label text="●" style="-fx-text-fill: #16A34A; -fx-font-size: 14px;" />
                    <Label text="Libre" style="-fx-text-fill: #64748B; -fx-font-size: 12px;" />
                </HBox>
                <HBox spacing="6" alignment="CENTER">
                    <Label text="●" style="-fx-text-fill: #DC2626; -fx-font-size: 14px;" />
                    <Label text="Ocupada" style="-fx-text-fill: #64748B; -fx-font-size: 12px;" />
                </HBox>
                <HBox spacing="6" alignment="CENTER">
                    <Label text="●" style="-fx-text-fill: #D97706; -fx-font-size: 14px;" />
                    <Label text="Pendiente de cobro" style="-fx-text-fill: #64748B; -fx-font-size: 12px;" />
                </HBox>
            </HBox>

            <!-- Grid de mesas -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                <FlowPane fx:id="mesasPane" hgap="16" vgap="16"
                          style="-fx-padding: 4;" />
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
