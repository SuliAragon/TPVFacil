<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.tpvfacil.core.ui.InicioController"
            style="-fx-background-color: linear-gradient(to bottom right, #0F172A, #1E3A5F);">

    <!-- CENTRO -->
    <center>
        <VBox spacing="0" alignment="CENTER">

            <!-- Logo / Título -->
            <VBox spacing="6" alignment="CENTER">
                <padding><Insets bottom="48" /></padding>
                <Label text="🧾 TPVFácil"
                       style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: white;
                              -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.4),8,0,0,2);"/>
                <Label text="Sistema de Punto de Venta con Verifactu"
                       style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.5);
                              -fx-font-weight: normal;"/>
            </VBox>

            <!-- Módulos -->
            <HBox spacing="24" alignment="CENTER">

                <!-- Hostelería -->
                <VBox fx:id="btnHosteleria" onMouseClicked="#abrirHosteleria"
                      styleClass="tarjeta-modulo"
                      prefWidth="220" prefHeight="160"
                      alignment="CENTER" spacing="12">
                    <padding><Insets topRightBottomLeft="24"/></padding>
                    <Label text="🍽"
                           style="-fx-font-size: 44px;"/>
                    <Label text="Hostelería"
                           style="-fx-font-size: 19px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Bares · Restaurantes"
                           style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.5);"/>
                </VBox>

                <!-- Comercio -->
                <VBox fx:id="btnComercio" onMouseClicked="#abrirComercio"
                      styleClass="tarjeta-modulo"
                      prefWidth="220" prefHeight="160"
                      alignment="CENTER" spacing="12">
                    <padding><Insets topRightBottomLeft="24"/></padding>
                    <Label text="🛍"
                           style="-fx-font-size: 44px;"/>
                    <Label text="Comercio"
                           style="-fx-font-size: 19px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Tiendas · Pequeño negocio"
                           style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.5);"/>
                </VBox>

            </HBox>

            <!-- Configuración -->
            <VBox alignment="CENTER" spacing="8">
                <padding><Insets top="36" /></padding>
                <Button text="⚙  Configuración" onAction="#abrirConfiguracion"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: rgba(255,255,255,0.45);
                               -fx-font-size: 12px; -fx-cursor: hand;
                               -fx-border-color: transparent; -fx-padding: 6 12;"/>
            </VBox>

        </VBox>
    </center>

    <!-- ABAJO: Banner DEMO -->
    <bottom>
        <HBox fx:id="bannerDemo" spacing="14" alignment="CENTER"
              styleClass="banner-demo">
            <Label fx:id="labelTicketsDemo"
                   text="⚠  MODO DEMO — Tickets hoy: 0/20"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Button text="Activar licencia →" onAction="#abrirActivacion"
                    style="-fx-background-color: rgba(0,0,0,0.25); -fx-text-fill: white;
                           -fx-font-size: 12px; -fx-font-weight: bold;
                           -fx-background-radius: 6; -fx-cursor: hand;
                           -fx-border-color: rgba(255,255,255,0.3); -fx-border-width: 1;
                           -fx-border-radius: 6; -fx-padding: 5 12;"/>
        </HBox>
    </bottom>
</BorderPane>
