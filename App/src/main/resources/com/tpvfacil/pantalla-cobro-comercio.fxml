<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<SplitPane dividerPositions="0.52"
           style="-fx-background-color: #F4F6F9;"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.tpvfacil.comercio.controller.CobroComercioController">
    <items>

        <!-- ═══ PANEL IZQUIERDO: RESUMEN ═══ -->
        <VBox spacing="14">
            <padding><Insets bottom="20" left="20" right="10" top="20" /></padding>

            <Label text="Resumen de Venta"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1B4F8A;" />

            <!-- Tabla de líneas -->
            <TableView fx:id="tablaResumen" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colDesc"    text="Concepto"  prefWidth="230" />
                    <TableColumn fx:id="colCant"    text="Cant."     prefWidth="55"
                                 style="-fx-alignment: CENTER;" />
                    <TableColumn fx:id="colImporte" text="Importe"   prefWidth="100"
                                 style="-fx-alignment: CENTER_RIGHT;" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>

            <!-- Desglose totales -->
            <VBox styleClass="panel-totales" spacing="6">
                <HBox alignment="CENTER_RIGHT" spacing="20">
                    <Label text="Base Imponible:" style="-fx-text-fill: #666;" />
                    <Label fx:id="lblBase" text="0,00 €" style="-fx-font-weight: bold;" />
                </HBox>
                <HBox alignment="CENTER_RIGHT" spacing="20">
                    <Label text="Cuota IVA:" style="-fx-text-fill: #666;" />
                    <Label fx:id="lblIva" text="0,00 €" style="-fx-font-weight: bold;" />
                </HBox>
                <Separator />
                <HBox alignment="CENTER_RIGHT" spacing="20">
                    <Label text="TOTAL:"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" />
                    <Label fx:id="lblTotal" text="0,00 €"
                           style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #1B4F8A;" />
                </HBox>
            </VBox>

            <!-- Opción de factura con NIF -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <CheckBox fx:id="chkFactura" text="Emitir factura con NIF" />
                <TextField fx:id="txtNif" promptText="NIF del cliente…"
                           disable="true" HBox.hgrow="ALWAYS" />
                <Button fx:id="btnBuscarCliente" text="Buscar"
                        disable="true" styleClass="btn-primario"
                        style="-fx-background-color: #1B4F8A; -fx-text-fill: white;
                               -fx-background-radius: 6; -fx-padding: 7 12;" />
            </HBox>
        </VBox>

        <!-- ═══ PANEL DERECHO: PAGO ═══ -->
        <VBox spacing="18" alignment="TOP_CENTER">
            <padding><Insets bottom="20" left="10" right="20" top="20" /></padding>

            <Label text="Forma de Pago"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" />

            <!-- Toggles de forma de pago -->
            <HBox spacing="10" alignment="CENTER">
                <ToggleButton fx:id="btnEfectivo" text="💵  Efectivo" selected="true"
                              styleClass="toggle-pago"
                              style="-fx-font-size: 15px; -fx-padding: 10 20;
                                     -fx-background-radius: 8; -fx-border-radius: 8;
                                     -fx-cursor: hand;" />
                <ToggleButton fx:id="btnTarjeta" text="💳  Tarjeta"
                              styleClass="toggle-pago"
                              style="-fx-font-size: 15px; -fx-padding: 10 20;
                                     -fx-background-radius: 8; -fx-border-radius: 8;
                                     -fx-cursor: hand;" />
                <ToggleButton fx:id="btnMixto" text="🔄  Mixto"
                              styleClass="toggle-pago"
                              style="-fx-font-size: 15px; -fx-padding: 10 20;
                                     -fx-background-radius: 8; -fx-border-radius: 8;
                                     -fx-cursor: hand;" />
            </HBox>

            <!-- Importe entregado + billetes -->
            <VBox styleClass="panel-totales" spacing="12" alignment="CENTER">
                <HBox spacing="10" alignment="CENTER">
                    <Label text="Entregado:" style="-fx-font-size: 17px; -fx-text-fill: #555;" />
                    <TextField fx:id="txtEntregado" text="0.00"
                               style="-fx-font-size: 26px; -fx-pref-width: 140;
                                      -fx-alignment: center-right; -fx-background-radius: 6;
                                      -fx-border-radius: 6; -fx-padding: 6 10;" />
                    <Label text="€" style="-fx-font-size: 22px; -fx-text-fill: #555;" />
                </HBox>

                <!-- Botones de billete -->
                <HBox spacing="10" alignment="CENTER">
                    <Button text="5 €"  onAction="#addBillete" styleClass="btn-billete"
                            style="-fx-background-color: #FFFDE7; -fx-border-color: #F9A825;
                                   -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 10 16;
                                   -fx-background-radius: 6; -fx-border-radius: 6; -fx-cursor: hand;" />
                    <Button text="10 €" onAction="#addBillete" styleClass="btn-billete"
                            style="-fx-background-color: #FFFDE7; -fx-border-color: #F9A825;
                                   -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 10 16;
                                   -fx-background-radius: 6; -fx-border-radius: 6; -fx-cursor: hand;" />
                    <Button text="20 €" onAction="#addBillete" styleClass="btn-billete"
                            style="-fx-background-color: #FFFDE7; -fx-border-color: #F9A825;
                                   -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 10 16;
                                   -fx-background-radius: 6; -fx-border-radius: 6; -fx-cursor: hand;" />
                    <Button text="50 €" onAction="#addBillete" styleClass="btn-billete"
                            style="-fx-background-color: #FFFDE7; -fx-border-color: #F9A825;
                                   -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 10 16;
                                   -fx-background-radius: 6; -fx-border-radius: 6; -fx-cursor: hand;" />
                </HBox>
            </VBox>

            <!-- Cambio (empieza en verde neutral) -->
            <HBox alignment="CENTER" spacing="16">
                <Label text="Cambio:" style="-fx-font-size: 20px; -fx-text-fill: #555;" />
                <Label fx:id="lblCambio" text="0,00 €" styleClass="label-cambio-ok"
                       style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #27AE60;" />
            </HBox>

            <Region VBox.vgrow="ALWAYS" />

            <!-- Botones de acción -->
            <HBox spacing="10">
                <Button text="✖  Cancelar" onAction="#cancelar"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"
                        style="-fx-font-size: 16px; -fx-padding: 14; -fx-background-color: #ECF0F1;
                               -fx-text-fill: #2C3E50; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-cursor: hand;" />
                <Button text="✅  CONFIRMAR COBRO" onAction="#confirmarCobro"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"
                        style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-padding: 14;
                               -fx-background-color: #27AE60; -fx-text-fill: white;
                               -fx-background-radius: 8; -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian,rgba(39,174,96,0.35),8,0,0,3);" />
            </HBox>
        </VBox>
    </items>
</SplitPane>
