<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane style="-fx-background-color: #F1F5F9;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.tpvfacil.comercio.controller.CobroComercioController">

    <center>
        <SplitPane dividerPositions="0.52" style="-fx-background-color: transparent;">
            <items>

                <!-- ═══ PANEL IZQUIERDO: RESUMEN ═══ -->
                <VBox spacing="16">
                    <padding><Insets bottom="24" left="24" right="12" top="24" /></padding>

                    <VBox spacing="4">
                        <Label text="Resumen de venta"
                               style="-fx-font-size: 11px; -fx-font-weight: bold;
                                      -fx-text-fill: #94A3B8; -fx-letter-spacing: 1;" />
                        <Label text="Detalle del pedido"
                               style="-fx-font-size: 22px; -fx-font-weight: bold;
                                      -fx-text-fill: #0F172A;" />
                    </VBox>

                    <!-- Tabla de líneas -->
                    <TableView fx:id="tablaResumen" VBox.vgrow="ALWAYS" styleClass="table-view">
                        <columns>
                            <TableColumn fx:id="colDesc"    text="Concepto"  prefWidth="220" />
                            <TableColumn fx:id="colCant"    text="Cant."     prefWidth="55"
                                         style="-fx-alignment: CENTER;" />
                            <TableColumn fx:id="colImporte" text="Importe"   prefWidth="100"
                                         style="-fx-alignment: CENTER_RIGHT;" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>

                    <!-- Desglose totales -->
                    <VBox styleClass="panel-totales" spacing="8">
                        <HBox alignment="CENTER_RIGHT" spacing="20">
                            <Label text="Base imponible"
                                   style="-fx-text-fill: #64748B; -fx-font-size: 13px;" />
                            <Label fx:id="lblBase" text="0,00 €"
                                   style="-fx-font-weight: bold; -fx-text-fill: #334155;" />
                        </HBox>
                        <HBox alignment="CENTER_RIGHT" spacing="20">
                            <Label text="Cuota IVA"
                                   style="-fx-text-fill: #64748B; -fx-font-size: 13px;" />
                            <Label fx:id="lblIva" text="0,00 €"
                                   style="-fx-font-weight: bold; -fx-text-fill: #334155;" />
                        </HBox>
                        <Separator />
                        <HBox alignment="CENTER_RIGHT" spacing="16">
                            <Label text="TOTAL"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold;
                                          -fx-text-fill: #64748B;" />
                            <Label fx:id="lblTotal" text="0,00 €"
                                   style="-fx-font-size: 38px; -fx-font-weight: bold;
                                          -fx-text-fill: #0F172A;" />
                        </HBox>
                    </VBox>

                    <!-- Factura con NIF -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <CheckBox fx:id="chkFactura" text="Emitir factura con NIF" />
                        <TextField fx:id="txtNif" promptText="NIF del cliente…"
                                   disable="true" HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnBuscarCliente" text="Buscar"
                                disable="true" styleClass="btn-primario"
                                style="-fx-background-color: #1D4ED8; -fx-text-fill: white;
                                       -fx-background-radius: 8; -fx-padding: 8 14;" />
                    </HBox>
                </VBox>

                <!-- ═══ PANEL DERECHO: PAGO ═══ -->
                <VBox spacing="20" alignment="TOP_CENTER"
                      style="-fx-background-color: white;">
                    <padding><Insets bottom="24" left="20" right="24" top="24" /></padding>

                    <VBox spacing="4">
                        <Label text="MÉTODO DE PAGO"
                               style="-fx-font-size: 11px; -fx-font-weight: bold;
                                      -fx-text-fill: #94A3B8; -fx-letter-spacing: 1;" />
                    </VBox>

                    <!-- Toggles de forma de pago -->
                    <HBox spacing="10" alignment="CENTER">
                        <ToggleButton fx:id="btnEfectivo" text="💵  Efectivo" selected="true"
                                      styleClass="toggle-pago" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                        <ToggleButton fx:id="btnTarjeta"  text="💳  Tarjeta"
                                      styleClass="toggle-pago" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                        <ToggleButton fx:id="btnMixto"    text="🔄  Mixto"
                                      styleClass="toggle-pago" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                    </HBox>

                    <!-- Importe entregado -->
                    <VBox styleClass="panel-totales" spacing="14" alignment="CENTER">

                        <Label text="Importe entregado"
                               style="-fx-font-size: 12px; -fx-text-fill: #64748B; -fx-font-weight: bold;" />

                        <HBox spacing="10" alignment="CENTER">
                            <TextField fx:id="txtEntregado" text="0.00"
                                       style="-fx-font-size: 30px; -fx-pref-width: 160;
                                              -fx-alignment: center-right;
                                              -fx-background-radius: 10; -fx-border-radius: 10;
                                              -fx-border-color: #E2E8F0; -fx-border-width: 1.5;
                                              -fx-padding: 8 12; -fx-font-weight: bold;" />
                            <Label text="€"
                                   style="-fx-font-size: 26px; -fx-text-fill: #64748B; -fx-font-weight: bold;" />
                        </HBox>

                        <!-- Billetes -->
                        <HBox spacing="10" alignment="CENTER">
                            <Button text="5 €"  onAction="#addBillete" styleClass="btn-billete" />
                            <Button text="10 €" onAction="#addBillete" styleClass="btn-billete" />
                            <Button text="20 €" onAction="#addBillete" styleClass="btn-billete" />
                            <Button text="50 €" onAction="#addBillete" styleClass="btn-billete" />
                        </HBox>
                    </VBox>

                    <!-- Cambio -->
                    <VBox alignment="CENTER" spacing="4">
                        <Label text="CAMBIO"
                               style="-fx-font-size: 11px; -fx-font-weight: bold;
                                      -fx-text-fill: #94A3B8; -fx-letter-spacing: 1;" />
                        <Label fx:id="lblCambio" text="0,00 €" styleClass="label-cambio-ok"
                               style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #16A34A;" />
                    </VBox>

                    <Region VBox.vgrow="ALWAYS" />

                    <!-- Botones de acción -->
                    <VBox spacing="10">
                        <Button text="✅  CONFIRMAR COBRO" onAction="#confirmarCobro"
                                maxWidth="Infinity"
                                styleClass="btn-accion-principal" />
                        <Button text="Cancelar" onAction="#cancelar"
                                maxWidth="Infinity"
                                style="-fx-font-size: 14px; -fx-padding: 12;
                                       -fx-background-color: transparent;
                                       -fx-text-fill: #64748B; -fx-font-weight: bold;
                                       -fx-border-color: #E2E8F0; -fx-border-width: 1.5;
                                       -fx-border-radius: 10; -fx-background-radius: 10;
                                       -fx-cursor: hand;" />
                    </VBox>
                </VBox>

            </items>
        </SplitPane>
    </center>
</BorderPane>
