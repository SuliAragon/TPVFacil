<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tpvfacil.comercio.controller.GestionStockController" style="-fx-background-color: #F4F6F9;">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Gestión de Inventario (Stock)" style="-fx-font-size: 20px; -fx-font-weight: bold;" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
        <Button text="💾 Guardar Cambios" onAction="#guardarCambios" style="-fx-base: #27AE60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8px 15px;" />
    </HBox>

    <HBox spacing="10">
        <TextField fx:id="buscadorField" promptText="Buscar producto por nombre..." prefWidth="300" />
        <Button text="Buscar" onAction="#filtrarTabla" />
    </HBox>

    <TableView fx:id="tablaStock" VBox.vgrow="ALWAYS" editable="true">
        <columns>
            <TableColumn fx:id="colAlerta" text="!" prefWidth="40" style="-fx-alignment: CENTER;" />
            <TableColumn fx:id="colNombre" text="Producto" prefWidth="250" />
            <TableColumn fx:id="colCategoria" text="Categoría" prefWidth="150" />
            <TableColumn fx:id="colStock" text="Stock Actual" prefWidth="100" style="-fx-alignment: CENTER;" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Leyenda:" style="-fx-font-weight: bold;" />
        <Label text="■ Agotado" style="-fx-text-fill: red; -fx-font-weight: bold;" />
        <Label text="■ Stock Bajo" style="-fx-text-fill: orange; -fx-font-weight: bold;" />
        <Label text="(-1 = No se controla stock)" style="-fx-text-fill: gray;" />
    </HBox>
</VBox>
