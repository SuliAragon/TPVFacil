<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>

<SplitPane dividerPositions="0.5" style="-fx-background-color: #F4F6F9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tpvfacil.hosteleria.controller.CobroHosteleriaController">
    <items>
        <!-- PANEL IZQUIERDO: RESUMEN -->
        <VBox spacing="15">
            <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

            <Label text="Resumen de la comanda" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

            <TableView fx:id="tablaResumen" VBox.vgrow="ALWAYS" style="-fx-font-size: 13px;">
                <columns>
                    <TableColumn fx:id="colDesc" text="Producto" prefWidth="200" />
                    <TableColumn fx:id="colCant" text="Cant." prefWidth="50" />
                    <TableColumn fx:id="colImporte" text="Importe" prefWidth="80" />
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            </TableView>

            <HBox spacing="20">
                <VBox spacing="3">
                    <Label text="Base imponible" style="-fx-font-size: 12px; -fx-text-fill: gray;" />
                    <Label fx:id="lblBase" text="0.00 €" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                </VBox>
                <VBox spacing="3">
                    <Label text="IVA" style="-fx-font-size: 12px; -fx-text-fill: gray;" />
                    <Label fx:id="lblIva" text="0.00 €" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                </VBox>
                <VBox spacing="3">
                    <Label text="TOTAL" style="-fx-font-size: 12px; -fx-text-fill: gray;" />
                    <Label fx:id="lblTotal" text="0.00 €" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1B4F8A;" />
                </VBox>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="÷ Dividir cuenta" onAction="#dividirCuenta" style="-fx-font-size: 12px;" />
                <Label fx:id="lblDivision" text="" style="-fx-font-size: 13px; -fx-text-fill: #8E44AD; -fx-font-weight: bold;" />
            </HBox>
        </VBox>

        <!-- PANEL DERECHO: PAGO -->
        <VBox spacing="15">
            <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

            <Label text="Forma de pago" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

            <HBox spacing="10" alignment="CENTER">
                <ToggleButton fx:id="btnEfectivo" text="💵 Efectivo" selected="true" style="-fx-font-size: 14px; -fx-padding: 10 20;" />
                <ToggleButton fx:id="btnTarjeta" text="💳 Tarjeta" style="-fx-font-size: 14px; -fx-padding: 10 20;" />
                <ToggleButton fx:id="btnMixto" text="🔀 Mixto" style="-fx-font-size: 14px; -fx-padding: 10 20;" />
            </HBox>

            <VBox spacing="5">
                <Label text="Entregado:" style="-fx-font-size: 14px;" />
                <TextField fx:id="txtEntregado" style="-fx-font-size: 20px; -fx-padding: 8;" promptText="0.00" />
            </VBox>

            <HBox spacing="8" alignment="CENTER">
                <Button text="5€" onAction="#addBillete5" style="-fx-font-size: 12px; -fx-padding: 6 14;" />
                <Button text="10€" onAction="#addBillete10" style="-fx-font-size: 12px; -fx-padding: 6 14;" />
                <Button text="20€" onAction="#addBillete20" style="-fx-font-size: 12px; -fx-padding: 6 14;" />
                <Button text="50€" onAction="#addBillete50" style="-fx-font-size: 12px; -fx-padding: 6 14;" />
            </HBox>

            <VBox spacing="3" alignment="CENTER">
                <Label text="Cambio" style="-fx-font-size: 14px; -fx-text-fill: gray;" />
                <Label fx:id="lblCambio" text="0.00 €" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #27AE60;" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <Button text="✅ CONFIRMAR COBRO" onAction="#confirmarCobro" maxWidth="Infinity" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-background-color: #27AE60; -fx-text-fill: white; -fx-padding: 15;">
                <cursor><Cursor fx:constant="HAND" /></cursor>
            </Button>

            <Button text="Cancelar" onAction="#cancelar" maxWidth="Infinity" style="-fx-font-size: 13px;" />
        </VBox>
    </items>
</SplitPane>
