<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tpvfacil.core.ui.DialogoCategoriaController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    
    <Label text="Datos de la Categoría" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
    
    <GridPane vgap="10" hgap="10">
        <Label text="Nombre:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <TextField fx:id="txtNombre" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="200" />
    </GridPane>
    
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar" onAction="#cancelar" />
        <Button text="Guardar" onAction="#guardar" style="-fx-base: #27AE60; -fx-text-fill: white;" />
    </HBox>
</VBox>
