<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tpvfacil.comercio.controller.DevolucionController" style="-fx-background-color: #F4F6F9; -fx-pref-width: 600; -fx-pref-height: 500;">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Devolución de Artículos" style="-fx-font-size: 20px; -fx-font-weight: bold;" />

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Buscar Factura:" />
        <TextField fx:id="txtBuscadorFactura" promptText="Nº Factura (ej. 1024)" prefWidth="150" />
        <Button text="🔍 Buscar" onAction="#buscarFactura" />
    </HBox>

    <TableView fx:id="tablaLineas" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colSelect" text="Devolver" prefWidth="70" style="-fx-alignment: center;" />
            <TableColumn fx:id="colProducto" text="Producto" prefWidth="250" />
            <TableColumn fx:id="colCantidad" text="Cant." prefWidth="60" style="-fx-alignment: center;" />
            <TableColumn fx:id="colTotal" text="Total" prefWidth="100" style="-fx-alignment: center-right;" />
        </columns>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="20">
        <Label text="Total a devolver:" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
        <Label fx:id="lblTotalDevolver" text="0.00 €" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #E74C3C;" />
    </HBox>

    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Label text="Forma de abono:" />
        <ComboBox fx:id="cmbFormaPago" prefWidth="150" />
    </HBox>

    <HBox spacing="10" alignment="BOTTOM_RIGHT" VBox.vgrow="SOMETIMES">
        <Button text="Cancelar" onAction="#cancelar" style="-fx-font-size: 14px; -fx-padding: 8px 15px;" />
        <Button text="Confirmar Devolución" fx:id="btnConfirmar" onAction="#confirmarDevolucion" disable="true" style="-fx-base: #E74C3C; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 8px 15px;" />
    </HBox>
</VBox>
