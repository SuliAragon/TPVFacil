<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<SplitPane dividerPositions="0.3" style="-fx-background-color: #F4F6F9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tpvfacil.core.ui.GestionCartaController">
    <items>
        <!-- PANEL IZQUIERDO: CATEGORÍAS -->
        <VBox spacing="10">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Categorías" style="-fx-font-size: 18px; -fx-font-weight: bold;" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                <Button text="+" onAction="#nuevaCategoria" />
                <Button text="✎" onAction="#editarCategoria" />
            </HBox>
            
            <ListView fx:id="listaCategorias" VBox.vgrow="ALWAYS" />
            
            <Label text="* Arrastra para reordenar" style="-fx-font-size: 10px; -fx-text-fill: gray;" />
        </VBox>
        
        <!-- PANEL DERECHO: PRODUCTOS -->
        <VBox spacing="10">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label fx:id="labelCategoriaSel" text="Productos" style="-fx-font-size: 18px; -fx-font-weight: bold;" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                <Button text="Nuevo Producto" onAction="#nuevoProducto" style="-fx-base: #27AE60; -fx-text-fill: white;" />
                <Button text="Editar" onAction="#editarProducto" />
                <Button text="Activar/Desactivar" onAction="#alternarEstadoProducto" />
            </HBox>
            
            <TableView fx:id="tablaProductos" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colProdNombre" text="Nombre" prefWidth="200" />
                    <TableColumn fx:id="colProdPrecio" text="Precio (Sin IVA)" prefWidth="120" />
                    <TableColumn fx:id="colProdIva" text="IVA %" prefWidth="80" />
                    <TableColumn fx:id="colProdBarras" text="Cód. Barras" prefWidth="120" />
                    <TableColumn fx:id="colProdEstado" text="Estado" prefWidth="80" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>
    </items>
</SplitPane>
