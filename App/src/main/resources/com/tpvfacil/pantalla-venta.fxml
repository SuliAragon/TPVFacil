<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane style="-fx-background-color: #F4F6F9;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.tpvfacil.comercio.controller.VentaController">

    <!-- ── BARRA DE MENÚ ────────────────────────────────────────── -->
    <top>
        <VBox>
            <MenuBar styleClass="menu-bar">
                <Menu text="Archivo">
                    <MenuItem text="⬅  Volver al Menú Principal" onAction="#volverInicio" />
                    <SeparatorMenuItem />
                    <MenuItem text="Salir" onAction="#salir" />
                </Menu>
                <Menu text="Gestión">
                    <MenuItem text="📋  Gestión de Carta (Productos)" onAction="#abrirGestionCarta" />
                    <MenuItem text="📦  Gestión de Stock"             onAction="#abrirGestionStock" />
                    <SeparatorMenuItem />
                    <MenuItem text="💾  Copias de Seguridad"          onAction="#abrirBackups" />
                </Menu>
                <Menu text="Caja">
                    <MenuItem text="🔒  Cierre de Caja" onAction="#abrirCierreCaja" />
                </Menu>
            </MenuBar>

            <!-- ── HEADER con nombre de módulo + reloj ── -->
            <HBox styleClass="toolbar-modulo" alignment="CENTER_LEFT" spacing="12">
                <Label text="🛍  TPV Comercio"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1B4F8A;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblReloj"
                       style="-fx-font-size: 14px; -fx-text-fill: #666;" />
                <Button text="⬅ Inicio" onAction="#volverInicio"
                        style="-fx-background-color: transparent; -fx-text-fill: #1B4F8A;
                               -fx-font-size: 13px; -fx-cursor: hand; -fx-underline: true;
                               -fx-padding: 4 8;" />
            </HBox>
        </VBox>
    </top>

    <!-- ── CUERPO PRINCIPAL ─────────────────────────────────────── -->
    <center>
        <SplitPane dividerPositions="0.62" style="-fx-background-color: transparent;">
            <items>

                <!-- ═══ PANEL IZQUIERDO: CATÁLOGO ═══ -->
                <VBox spacing="10">
                    <padding><Insets bottom="12" left="14" right="8" top="12" /></padding>

                    <!-- Buscador -->
                    <TextField fx:id="buscadorField"
                               promptText="🔍  Buscar producto o escanear código de barras…"
                               styleClass="buscador-principal" />

                    <!-- Barra de categorías (cargada dinámicamente) -->
                    <HBox fx:id="categoriaBar" spacing="8" alignment="CENTER_LEFT"
                          style="-fx-padding: 2 0;" />

                    <!-- Catálogo en cuadrícula -->
                    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                style="-fx-background-color: transparent;">
                        <FlowPane fx:id="catalogoPane" hgap="12" vgap="12"
                                  style="-fx-padding: 4;" />
                    </ScrollPane>
                </VBox>

                <!-- ═══ PANEL DERECHO: CESTA ═══ -->
                <VBox spacing="10" styleClass="panel-cesta">
                    <padding><Insets bottom="14" left="14" right="14" top="12" /></padding>

                    <Label text="CESTA DE COMPRA"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" />

                    <!-- Tabla de ítems -->
                    <TableView fx:id="tablaCesta" VBox.vgrow="ALWAYS" styleClass="table-view"
                               style="-fx-font-size: 13px;" placeholder="&lt;Label text='La cesta está vacía'/&gt;">
                        <columns>
                            <TableColumn fx:id="colProducto"  text="Producto"  prefWidth="145" />
                            <TableColumn fx:id="colCantidad"  text="Cant."     prefWidth="50"  style="-fx-alignment: CENTER;" />
                            <TableColumn fx:id="colSubtotal"  text="Importe"   prefWidth="80"  style="-fx-alignment: CENTER_RIGHT;" />
                            <TableColumn fx:id="colAcciones"  text=""          prefWidth="90"  />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>

                    <!-- Total -->
                    <VBox styleClass="panel-totales" spacing="4">
                        <HBox alignment="CENTER_RIGHT" spacing="8">
                            <Label text="TOTAL:"
                                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #555;" />
                            <Label fx:id="labelTotal" text="0,00 €" styleClass="label-total" />
                        </HBox>
                    </VBox>

                    <!-- Botones secundarios -->
                    <HBox spacing="8">
                        <Button text="🗑  Limpiar" onAction="#limpiarCesta"
                                styleClass="btn-peligro"
                                HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                style="-fx-font-size: 13px; -fx-background-color: #E74C3C;
                                       -fx-text-fill: white; -fx-font-weight: bold;
                                       -fx-background-radius: 6; -fx-padding: 8 10;" />
                        <Button text="↩  Devolución" onAction="#abrirDevolucion"
                                styleClass="btn-aviso"
                                HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                style="-fx-font-size: 13px; -fx-background-color: #E67E22;
                                       -fx-text-fill: white; -fx-font-weight: bold;
                                       -fx-background-radius: 6; -fx-padding: 8 10;" />
                    </HBox>

                    <!-- Botón COBRAR -->
                    <Button fx:id="btnCobrar" text="💳  COBRAR  0,00 €"
                            onAction="#cobrar"
                            styleClass="btn-accion-principal"
                            maxWidth="Infinity"
                            style="-fx-background-color: #27AE60; -fx-text-fill: white;
                                   -fx-font-size: 20px; -fx-font-weight: bold;
                                   -fx-background-radius: 8; -fx-padding: 16 20;
                                   -fx-effect: dropshadow(gaussian,rgba(39,174,96,0.35),8,0,0,3);" />

                </VBox>
            </items>
        </SplitPane>
    </center>
</BorderPane>
