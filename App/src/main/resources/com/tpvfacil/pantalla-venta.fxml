<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane style="-fx-background-color: #F1F5F9;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.tpvfacil.comercio.controller.VentaController">

    <!-- ── CABECERA OSCURA ──────────────────────────────────────── -->
    <top>
        <VBox>
            <!-- Header principal -->
            <HBox styleClass="header-app" alignment="CENTER_LEFT" spacing="16">
                <Label text="🧾 TPVFácil" styleClass="header-logo" />
                <Label text="TPV Comercio"  styleClass="header-modulo" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblReloj" styleClass="header-reloj" />
                <Button text="≡  Gestión"   onAction="#abrirGestionCarta"  styleClass="header-btn" />
                <Button text="📦 Stock"      onAction="#abrirGestionStock"  styleClass="header-btn" />
                <Button text="🔒 Caja"       onAction="#abrirCierreCaja"    styleClass="header-btn" />
                <Button text="⬅ Inicio"     onAction="#volverInicio"        styleClass="header-btn-volver" />
            </HBox>

            <!-- Sub-barra de acceso extra (Backup etc.) solo via menu oscuro -->
            <MenuBar styleClass="menu-bar" style="-fx-padding: 1 8;">
                <Menu text="Más opciones">
                    <MenuItem text="💾  Copias de Seguridad"  onAction="#abrirBackups" />
                    <MenuItem text="↩  Devolución"            onAction="#abrirDevolucion" />
                    <SeparatorMenuItem />
                    <MenuItem text="Salir de la aplicación"   onAction="#salir" />
                </Menu>
            </MenuBar>
        </VBox>
    </top>

    <!-- ── CUERPO PRINCIPAL ─────────────────────────────────────── -->
    <center>
        <SplitPane dividerPositions="0.63" style="-fx-background-color: transparent; -fx-padding: 0;">

            <!-- ═══ PANEL IZQUIERDO: CATÁLOGO ═══ -->
            <VBox spacing="12">
                <padding><Insets bottom="14" left="16" right="10" top="14" /></padding>

                <!-- Buscador -->
                <TextField fx:id="buscadorField"
                           promptText="🔍  Buscar producto o escanear código de barras…"
                           styleClass="buscador-principal" />

                <!-- Barra de categorías -->
                <HBox fx:id="categoriaBar" spacing="8" alignment="CENTER_LEFT"
                      style="-fx-padding: 2 0;" />

                <!-- Catálogo -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <FlowPane fx:id="catalogoPane" hgap="14" vgap="14"
                              style="-fx-padding: 4 2;" />
                </ScrollPane>
            </VBox>

            <!-- ═══ PANEL DERECHO: CESTA ═══ -->
            <VBox spacing="10" styleClass="panel-cesta">
                <padding><Insets bottom="16" left="16" right="16" top="14" /></padding>

                <!-- Título cesta -->
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="CESTA"
                           style="-fx-font-size: 12px; -fx-font-weight: bold;
                                  -fx-text-fill: #94A3B8; -fx-letter-spacing: 1px;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="🗑  Limpiar" onAction="#limpiarCesta"
                            style="-fx-background-color: transparent; -fx-text-fill: #DC2626;
                                   -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 3 6;
                                   -fx-border-color: transparent;" />
                </HBox>

                <!-- Tabla de ítems -->
                <TableView fx:id="tablaCesta" VBox.vgrow="ALWAYS" styleClass="table-view"
                           style="-fx-font-size: 13px;">
                    <columns>
                        <TableColumn fx:id="colProducto"  text="Producto"  prefWidth="145" />
                        <TableColumn fx:id="colCantidad"  text="Cant."     prefWidth="50"
                                     style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colSubtotal"  text="Importe"   prefWidth="75"
                                     style="-fx-alignment: CENTER_RIGHT;" />
                        <TableColumn fx:id="colAcciones"  text=""          prefWidth="80" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <placeholder>
                        <VBox alignment="CENTER" spacing="6">
                            <Label text="🛒" style="-fx-font-size: 32px;" />
                            <Label text="La cesta está vacía"
                                   style="-fx-text-fill: #94A3B8; -fx-font-size: 13px;" />
                        </VBox>
                    </placeholder>
                </TableView>

                <!-- Bloque total -->
                <VBox styleClass="panel-totales" spacing="6">
                    <HBox alignment="CENTER_RIGHT" spacing="10">
                        <Label text="TOTAL"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #64748B;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="labelTotal" text="0,00 €" styleClass="label-total" />
                    </HBox>
                </VBox>

                <!-- Devolución (secundaria) -->
                <Button text="↩  Devolución" onAction="#abrirDevolucion"
                        maxWidth="Infinity"
                        style="-fx-font-size: 13px; -fx-background-color: transparent;
                               -fx-text-fill: #64748B; -fx-font-weight: bold;
                               -fx-border-color: #E2E8F0; -fx-border-width: 1;
                               -fx-border-radius: 8; -fx-background-radius: 8;
                               -fx-padding: 8 10; -fx-cursor: hand;" />

                <!-- COBRAR -->
                <Button fx:id="btnCobrar" text="💳  COBRAR  0,00 €"
                        onAction="#cobrar"
                        styleClass="btn-accion-principal"
                        maxWidth="Infinity" />
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
