<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.tpvfacil.core.ui.PrimerArranqueController"
      spacing="0"
      style="-fx-background-color: white;">

    <!-- Cabecera -->
    <HBox style="-fx-background-color: #1B4F8A; -fx-padding: 16 24;">
        <Label text="Configuración inicial de TPVFácil"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
    </HBox>

    <!-- Indicadores de paso -->
    <HBox spacing="8" alignment="CENTER" style="-fx-padding: 16; -fx-background-color: #f8f8f8;">
        <Label fx:id="indicador1" text="1"/>
        <Label text="Datos del negocio" style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
        <Label text="——" style="-fx-text-fill: #ccc;"/>
        <Label fx:id="indicador2" text="2"/>
        <Label text="Certificado" style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
        <Label text="——" style="-fx-text-fill: #ccc;"/>
        <Label fx:id="indicador3" text="3"/>
        <Label text="Impresoras" style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
    </HBox>

    <Separator/>

    <!-- ===== PASO 1: Datos del negocio ===== -->
    <StackPane fx:id="paso1" style="-fx-padding: 24;">
        <VBox spacing="14">
            <Label text="Datos del negocio"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
            <Label text="Estos datos aparecerán en todos los tickets y facturas."
                   style="-fx-font-size: 12px; -fx-text-fill: #888;"/>

            <GridPane hgap="12" vgap="10">
                <columnConstraints>
                    <ColumnConstraints minWidth="120" maxWidth="140"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Nombre del negocio *" GridPane.rowIndex="0" GridPane.columnIndex="0"
                       style="-fx-font-size: 13px;"/>
                <TextField fx:id="campoNombreNegocio" GridPane.rowIndex="0" GridPane.columnIndex="1"
                           promptText="Ej: Bar La Taberna de Juan"/>

                <Label text="NIF / CIF *" GridPane.rowIndex="1" GridPane.columnIndex="0"
                       style="-fx-font-size: 13px;"/>
                <TextField fx:id="campoNif" GridPane.rowIndex="1" GridPane.columnIndex="1"
                           promptText="Ej: 12345678Z o B12345678"/>

                <Label text="Dirección completa *" GridPane.rowIndex="2" GridPane.columnIndex="0"
                       style="-fx-font-size: 13px;"/>
                <TextField fx:id="campoDireccion" GridPane.rowIndex="2" GridPane.columnIndex="1"
                           promptText="Ej: Calle Mayor 10, 28001 Madrid"/>
            </GridPane>

            <Label fx:id="labelErrorPaso1" text=""
                   style="-fx-text-fill: #E74C3C; -fx-font-size: 12px;"/>
        </VBox>
    </StackPane>

    <!-- ===== PASO 2: Certificado Verifactu ===== -->
    <StackPane fx:id="paso2" visible="false" managed="false" style="-fx-padding: 24;">
        <VBox spacing="14">
            <Label text="Certificado Verifactu (opcional)"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
            <Label text="Necesario para emitir facturas legales (Verifactu producción). Puedes configurarlo más tarde."
                   style="-fx-font-size: 12px; -fx-text-fill: #888;" wrapText="true"/>

            <GridPane hgap="12" vgap="10">
                <columnConstraints>
                    <ColumnConstraints minWidth="120" maxWidth="140"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Archivo .p12 / .pfx" GridPane.rowIndex="0" GridPane.columnIndex="0"
                       style="-fx-font-size: 13px;"/>
                <HBox spacing="8" GridPane.rowIndex="0" GridPane.columnIndex="1">
                    <TextField fx:id="campoRutaCertificado" promptText="Ruta al certificado..."
                               HBox.hgrow="ALWAYS" editable="false"/>
                    <Button text="Examinar..." onAction="#seleccionarCertificado"
                            style="-fx-background-color: #1B4F8A; -fx-text-fill: white;
                                   -fx-background-radius: 4; -fx-cursor: hand;"/>
                </HBox>

                <Label text="Contraseña" GridPane.rowIndex="1" GridPane.columnIndex="0"
                       style="-fx-font-size: 13px;"/>
                <PasswordField fx:id="campoPasswordCertificado" GridPane.rowIndex="1" GridPane.columnIndex="1"
                               promptText="Contraseña del certificado"/>
            </GridPane>

            <Label fx:id="labelErrorPaso2" text=""
                   style="-fx-text-fill: #E74C3C; -fx-font-size: 12px;"/>
        </VBox>
    </StackPane>

    <!-- ===== PASO 3: Impresoras ===== -->
    <StackPane fx:id="paso3" visible="false" managed="false" style="-fx-padding: 24;">
        <VBox spacing="14">
            <Label text="Impresoras (opcional)"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
            <Label text="Configura la impresora de tickets. Puedes cambiarlo más tarde en Configuración."
                   style="-fx-font-size: 12px; -fx-text-fill: #888;" wrapText="true"/>

            <GridPane hgap="12" vgap="10">
                <columnConstraints>
                    <ColumnConstraints minWidth="120" maxWidth="140"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Impresora tickets" GridPane.rowIndex="0" GridPane.columnIndex="0"
                       style="-fx-font-size: 13px;"/>
                <TextField fx:id="campoImpresoraTickets" GridPane.rowIndex="0" GridPane.columnIndex="1"
                           promptText="Nombre de la impresora de tickets"/>

                <Label text="Impresora cocina" GridPane.rowIndex="1" GridPane.columnIndex="0"
                       style="-fx-font-size: 13px;"/>
                <TextField fx:id="campoImpresoraCocina" GridPane.rowIndex="1" GridPane.columnIndex="1"
                           promptText="Solo hostelería (opcional)"/>

                <Label text="Ancho papel" GridPane.rowIndex="2" GridPane.columnIndex="0"
                       style="-fx-font-size: 13px;"/>
                <HBox spacing="16" alignment="CENTER_LEFT" GridPane.rowIndex="2" GridPane.columnIndex="1">
                    <RadioButton fx:id="radio58mm" text="58 mm" toggleGroup="$grupoPapel"/>
                    <RadioButton fx:id="radio80mm" text="80 mm (recomendado)" toggleGroup="$grupoPapel"
                                 selected="true"/>
                </HBox>
            </GridPane>
        </VBox>
    </StackPane>

    <Region VBox.vgrow="ALWAYS"/>

    <!-- Barra de botones inferior -->
    <HBox style="-fx-background-color: #f8f8f8; -fx-padding: 12 24; -fx-border-color: #eee;"
          alignment="CENTER_RIGHT" spacing="10">
        <Button text="← Anterior" onAction="#anterior"
                style="-fx-background-color: #95a5a6; -fx-text-fill: white;
                       -fx-background-radius: 4; -fx-cursor: hand; -fx-padding: 8 16;"/>
        <Button text="Omitir este paso" onAction="#saltarPaso"
                style="-fx-background-color: transparent; -fx-text-fill: #888;
                       -fx-cursor: hand; -fx-underline: true; -fx-border-color: transparent;"/>
        <Button text="Siguiente →" onAction="#siguiente"
                style="-fx-background-color: #1B4F8A; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 4;
                       -fx-cursor: hand; -fx-padding: 8 20;"/>
    </HBox>
</VBox>
