<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>

<VBox spacing="0" style="-fx-background-color: #F4F6F9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tpvfacil.hosteleria.controller.ComandaController">

    <!-- Cabecera -->
    <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: #2C3E50; -fx-padding: 12 20;">
        <Label fx:id="lblMesaInfo" text="Mesa" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" />
        <Label fx:id="lblTiempoAbierta" text="" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.7);" />
        <Region HBox.hgrow="ALWAYS" />
        <Label text="Comensales:" style="-fx-text-fill: white; -fx-font-size: 13px;" />
        <Spinner fx:id="spnComensales" prefWidth="70" />
    </HBox>

    <!-- Cuerpo principal -->
    <SplitPane dividerPositions="0.55" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
        <items>
            <!-- PANEL IZQUIERDO: COMANDA -->
            <VBox spacing="10">
                <padding><Insets bottom="10" left="10" right="10" top="10" /></padding>
                <Label text="COMANDA" style="-fx-font-size: 16px; -fx-font-weight: bold;" />

                <TableView fx:id="tablaComanda" VBox.vgrow="ALWAYS" style="-fx-font-size: 13px;">
                    <columns>
                        <TableColumn fx:id="colProducto" text="Producto" prefWidth="180" />
                        <TableColumn fx:id="colCant" text="Cant." prefWidth="50" />
                        <TableColumn fx:id="colPrecio" text="Precio" prefWidth="80" />
                        <TableColumn fx:id="colAcciones" text="" prefWidth="90" />
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Label text="TOTAL:" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                    <Label fx:id="lblTotal" text="0.00 €" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1B4F8A;" />
                </HBox>
            </VBox>

            <!-- PANEL DERECHO: CARTA -->
            <VBox spacing="8">
                <padding><Insets bottom="10" left="10" right="10" top="10" /></padding>
                <Label text="CARTA" style="-fx-font-size: 16px; -fx-font-weight: bold;" />

                <HBox fx:id="categoriaBar" spacing="6" alignment="CENTER_LEFT" />

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                    <FlowPane fx:id="cartaPane" hgap="8" vgap="8" style="-fx-padding: 5;" />
                </ScrollPane>
            </VBox>
        </items>
    </SplitPane>

    <!-- Barra de acciones inferior -->
    <HBox spacing="10" alignment="CENTER" style="-fx-background-color: #ECF0F1; -fx-padding: 12 20;">
        <Button text="📤 Enviar a cocina" onAction="#enviarACocina" style="-fx-font-size: 14px; -fx-base: #E67E22; -fx-text-fill: white; -fx-padding: 8 18;">
            <cursor><Cursor fx:constant="HAND" /></cursor>
        </Button>
        <Button text="💳 Cobrar" onAction="#cobrar" style="-fx-font-size: 14px; -fx-base: #27AE60; -fx-text-fill: white; -fx-padding: 8 18;">
            <cursor><Cursor fx:constant="HAND" /></cursor>
        </Button>
        <Button text="📝 Observaciones" onAction="#editarObservaciones" style="-fx-font-size: 13px;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="← Mesas" onAction="#volverMesas" style="-fx-font-size: 13px;" />
    </HBox>
</VBox>
