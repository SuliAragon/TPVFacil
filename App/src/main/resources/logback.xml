<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Log a consola durante desarrollo -->
    <appender name="CONSOLA" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} [%level] %logger{30} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Log a archivo en el directorio de datos de la aplicación -->
    <appender name="ARCHIVO" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${user.home}/.tpvfacil/logs/tpvfacil.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${user.home}/.tpvfacil/logs/tpvfacil.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%level] %logger{40} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLA"/>
        <appender-ref ref="ARCHIVO"/>
    </root>

    <!-- Reducir ruido de librerías externas -->
    <logger name="org.xerial" level="WARN"/>
    <logger name="com.sun.xml" level="WARN"/>

</configuration>
